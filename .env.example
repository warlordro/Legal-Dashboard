# Legal Dashboard — .env.example
#
# Copiaza acest fisier in `.env` si completeaza valorile in functie de modul de
# rulare (desktop Electron vs server web). Pe desktop majoritatea variabilelor
# au default-uri sigure si pot fi lasate goale; pe server (web mode) trebuie
# setate explicit cele marcate REQUIRED-WEB.
#
# Format: VAR=valoare  # REQUIRED|OPTIONAL — descriere
# Niciuna dintre aceste variabile nu trebuie commit-uita cu valori reale.

# ============================================================================
# Mod si bind
# ============================================================================

NODE_ENV=                              # OPTIONAL — "production" | "development" (default development); afecteaza dotenv override + secure cookies
LEGAL_DASHBOARD_PORT=3002              # OPTIONAL — port HTTP backend (default 3002)
HOST=127.0.0.1                         # OPTIONAL — bind address (default 127.0.0.1 = loopback only)
LEGAL_DASHBOARD_ALLOW_REMOTE=          # OPTIONAL — "1" pentru a permite bind non-loopback (web mode); cere si LEGAL_DASHBOARD_AUTH_MODE=web + JWT valid, altfel boot-ul esueaza; pe desktop lasa gol
LEGAL_DASHBOARD_TRUSTED_PROXY_CIDR=    # OPTIONAL - CIDR proxy trusted pentru X-Forwarded-For (ex. 172.16.0.0/12 in Docker); lasa gol pe desktop
LEGAL_DASHBOARD_FORCE_BOOT=            # OPTIONAL - "1" pentru reclaim manual al instance lock-ului dupa crash/stale lock

# ============================================================================
# Auth (web mode) — desktop ignora, web mode (LEGAL_DASHBOARD_ALLOW_REMOTE=1) le foloseste
# ============================================================================

LEGAL_DASHBOARD_AUTH_MODE=             # OPTIONAL — "desktop" (default) | "web" (forteaza JWT validation pe rute)
APP_MODE=                              # OPTIONAL — alias legacy pentru LEGAL_DASHBOARD_AUTH_MODE; folosit doar daca LEGAL_DASHBOARD_AUTH_MODE nu e setat
LEGAL_DASHBOARD_JWT_SECRET=            # REQUIRED-WEB — secret HS256 pentru token-urile sesiunii (min 32 chars random); fara el web mode refuza pornirea
JWT_SECRET=                            # OPTIONAL — alias legacy pentru LEGAL_DASHBOARD_JWT_SECRET; folosit doar daca LEGAL_DASHBOARD_JWT_SECRET nu e setat
LEGAL_DASHBOARD_JWT_ISSUER=            # REQUIRED-WEB — iss claim asteptat in JWT; fara el web mode refuza pornirea
LEGAL_DASHBOARD_JWT_AUDIENCE=          # REQUIRED-WEB — aud claim asteptat in JWT; fara el web mode refuza pornirea
LEGAL_DASHBOARD_JWT_TTL_SECONDS=       # OPTIONAL — TTL token sesiune in secunde (default 3600, range 60..86400)
LEGAL_DASHBOARD_AUTH_COOKIE_SECURE=    # OPTIONAL — "1" forteaza cookies Secure flag (HTTPS only); web mode prod ar trebui "1"
TENANT_KEY_ENCRYPTION_SECRET=          # REQUIRED-WEB — base64 care decodeaza exact 32 bytes; master key AES-256-GCM pentru tenant_api_keys. OPTIONAL desktop. Pastreaza separat de DB backup; daca il pierzi, adminul trebuie sa reintroduca toate cheile in /admin/keys.

# ============================================================================
# Storage si migrations
# ============================================================================

LEGAL_DASHBOARD_DB_PATH=               # OPTIONAL — path absolut catre legal-dashboard.db; default = userData Electron pe desktop, ./data/ in standalone
MIGRATIONS_STRICT=                     # OPTIONAL — "1" = abort la sha mismatch fara self-heal (CI gate); default = self-heal CRLF/BOM la boot

# ============================================================================
# Monitoring (PortalJust SOAP scheduler)
# ============================================================================

MONITORING_ENABLED=                    # OPTIONAL — "0" dezactiveaza scheduler-ul (joburile raman in DB, dar nu mai claim-uiesc); default = enabled
MONITORING_DISABLED_KINDS=             # OPTIONAL — comma-sep tipuri excluse din claim (ex. "dosar_soap,name_soap"); kill switch pentru sursa upstream cu probleme

ICCJ_ROUTES_DISABLED=                  # OPTIONAL — "1" returneaza 503 pe rutele interactive ICCJ (/api/dosare-iccj, /api/termene-iccj); kill switch daca scj.ro blocheaza IP-ul (separat de MONITORING_DISABLED_KINDS, care opreste doar scheduler-ul)
ICCJ_TIMEOUT_MS=                       # OPTIONAL — timeout per request upstream scj.ro (default 30000)
ICCJ_MAX_RESPONSE_BYTES=               # OPTIONAL — cap dimensiune raspuns scj.ro (default 20971520 = 20MB)
ICCJ_ENRICH_BUDGET_MS=                 # OPTIONAL — buget total enrich server-side per cautare; randurile neatinse raman ne-imbogatite (default 45000)

# ============================================================================
# Email (SMTP) — optional pe desktop, recomandat pe server
# ============================================================================
# Daca oricare dintre SMTP_HOST/PORT/USER/PASS/FROM lipseste, dispatcher-ul de
# email scurt-circuiteaza inainte de SELECT (panoul UI arata "SMTP off"). Boot-ul
# nu fail-eaza, dar alertele si daily report-ul nu se trimit.

SMTP_HOST=                             # OPTIONAL — hostname server SMTP (ex. smtp.gmail.com)
SMTP_PORT=                             # OPTIONAL — port SMTP (587 = STARTTLS, 465 = TLS implicit)
SMTP_USER=                             # OPTIONAL — username SMTP
SMTP_PASS=                             # OPTIONAL — parola sau app-password SMTP (Gmail: app-password din 2FA)
SMTP_FROM=                             # OPTIONAL — adresa expeditor (ex. "Legal Dashboard <noreply@example.com>")
SMTP_SECURE=                           # OPTIONAL — "true" forteaza TLS implicit, "false" forteaza STARTTLS; default = (port === 465)
DAILY_REPORT_HOUR=                     # OPTIONAL — ora locala (0-23) la care ruleaza scheduler-ul de raport zilnic; default 9
FX_PLAUSIBLE_EUR_USD_MIN=             # OPTIONAL - prag minim plausibil BCE EUR/USD; default 0.5
FX_PLAUSIBLE_EUR_USD_MAX=             # OPTIONAL - prag maxim plausibil BCE EUR/USD; default 2.0

# ============================================================================
# AI providers — chei API per provider
# ============================================================================
# Pe desktop cheile sunt stocate de regula in safeStorage (DPAPI/Keychain) prin
# UI; env vars sunt fallback. In web mode v2.30.0, cheile sunt configurate de
# admin in /admin/keys si criptate in tenant_api_keys; env vars raman override
# operational cu prioritate peste DB.

ANTHROPIC_API_KEY=                     # OPTIONAL — Claude API key (https://console.anthropic.com)
OPENAI_API_KEY=                        # OPTIONAL — OpenAI API key (https://platform.openai.com/api-keys)
GOOGLE_AI_KEY=                         # OPTIONAL — Google Generative AI key (https://aistudio.google.com/apikey)

# ============================================================================
OPENROUTER_API_KEY=                    # OPTIONAL - OpenRouter unified API key; daca e setata, AI-ul poate ruta prin OpenRouter
OPENROUTER_DISABLED=                   # OPTIONAL - "1" dezactiveaza imediat OpenRouter si lasa doar mode=native
OPENROUTER_MODEL_OVERRIDES=            # OPTIONAL - "modelKey:openrouter/slug,..." pentru hot-patch slug-uri fara rebuild

# RNPM operational kill switches
# ============================================================================

RNPM_AUDIT_CAP_HIT_DISABLED=           # OPTIONAL — "1" sare INSERT-ul `rnpm.cap_hit` din audit_log (kill switch operational pentru contention sau crestere suspecta tabel audit); restul flow-ului SSE/decision/captchasUsed ramane neschimbat
RNPM_RUNTIME_VALIDATION_DISABLED=      # OPTIONAL - "1" dezactiveaza temporar validarea runtime RNPM fail-closed; foloseste doar ca rollback operational
LEGAL_DASHBOARD_RNPM_AUTOCOMPACT_DISABLED= # OPTIONAL - "1" dezactiveaza autocompact-ul dupa stergeri
LEGAL_DASHBOARD_RNPM_AUTOCOMPACT_MIN_FREE_MB= # OPTIONAL - prag absolut MB pentru autocompact (default 10; fractii finite >=0 permise)
LEGAL_DASHBOARD_DEFAULT_RNPM_STORAGE_MB=    # OPTIONAL - limita implicita per user pentru baza RNPM vie (default 500 MB; 0 sau negativ = nelimitat)
LEGAL_DASHBOARD_RNPM_BACKUP_CAP_MB=         # OPTIONAL - plafon best-effort per jail de backup RNPM (default 500 MB; 0 sau negativ = nelimitat)
RNPM_TIMEOUT_MS=                       # OPTIONAL — timeout per fetch RNPM in ms (default 60000)

# ============================================================================
# RNPM constants override (v2.22.0 — externalizat din hardcoded)
# ============================================================================
# Toate au valori default sigure in cod; override doar daca RNPM roteste
# sitekey-ul/pageurl-ul sau cand UA-ul vechi e rate-limited.
RNPM_SITEKEY=                          # OPTIONAL — public hCaptcha sitekey (NU e secret); default 6Lff9LsUAAAAAO1gN9y3YMSyX94MS4Yh5zPqePkT
RNPM_PAGEURL=                          # OPTIONAL — pageurl trimis catre solver-ul de captcha; default https://mj.rnpm.ro/
RNPM_USER_AGENT=                       # OPTIONAL — User-Agent header pentru fetch-uri RNPM; default Chrome 125 Windows desktop
