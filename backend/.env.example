# Legal Dashboard — backend environment variables
# Copy to backend/.env and fill in only what you need. Desktop mode has safe
# defaults; web mode has required auth fields documented below.
#
# AI provider keys: if set here, env takes PRECEDENCE over keys saved in the
# in-app "Setari AI" dialog on desktop and over tenant DB keys in web mode.
# In web mode v2.30.0, admins normally configure keys through /admin/keys;
# they are encrypted in tenant_api_keys with TENANT_KEY_ENCRYPTION_SECRET.

# Anthropic Claude API key — https://console.anthropic.com/
# OPTIONAL
ANTHROPIC_API_KEY=

# OpenAI API key — https://platform.openai.com/api-keys
# OPTIONAL
OPENAI_API_KEY=

# Google AI (Gemini) API key — https://aistudio.google.com/app/apikey
# OPTIONAL
GOOGLE_AI_KEY=

# OpenRouter unified API key. When set, routes AI through OpenRouter in web mode
# and can override native keys for desktop/server operations.
# OPTIONAL
OPENROUTER_API_KEY=

# Operational kill switch. Set to "1" to fail OpenRouter calls immediately.
# OPTIONAL
OPENROUTER_DISABLED=

# Hot-patch OpenRouter model slugs without a backend rebuild.
# Format: modelKey:provider/slug,otherKey:provider/other-slug
# OPTIONAL
OPENROUTER_MODEL_OVERRIDES=

# HTTP bind address. Loopback only (127.0.0.1 / localhost / ::1) is accepted
# by default. Any other value is refused unless LEGAL_DASHBOARD_ALLOW_REMOTE=1
# is set explicitly — prevents accidental LAN exposure via a stray HOST=0.0.0.0.
# OPTIONAL — default 127.0.0.1
HOST=127.0.0.1

# Opt-in switch for binding to non-loopback addresses. Set to "1" together
# with HOST=0.0.0.0 (or a specific interface) when hosting the backend for
# multiple clients. PR-9 cere si LEGAL_DASHBOARD_AUTH_MODE=web cu JWT valid;
# remote bind fara web auth e eroare fatala la boot. Keep unset for desktop
# Electron use.
# OPTIONAL
LEGAL_DASHBOARD_ALLOW_REMOTE=

# Trusted proxy CIDR list for X-Forwarded-For. Empty on desktop. In Docker deploy set to the internal network, e.g. 172.16.0.0/12.
LEGAL_DASHBOARD_TRUSTED_PROXY_CIDR=

# Break-glass stale SQLite instance-lock reclaim. Use only after confirming the old process is gone.
LEGAL_DASHBOARD_FORCE_BOOT=

# Backend port. Electron injects this automatically; override only for
# manual runs or alternative port assignments.
# OPTIONAL — default 3002
LEGAL_DASHBOARD_PORT=

# SQLite DB path. Electron sets this to %APPDATA%/legal-dashboard/legal-dashboard.db
# OPTIONAL — leave empty for default in dev (./legal-dashboard-dev.db)
LEGAL_DASHBOARD_DB_PATH=

# AUTH MODE
# Desktop is the default and keeps the seeded local user exactly as before.
# Web mode is opt-in and fail-closed: API requests require a valid signed
# session token/JWT and a matching active row in `users`.
# Web mode REQUIRES JWT_SECRET + JWT_ISSUER + JWT_AUDIENCE (or the
# LEGAL_DASHBOARD_* aliases below).
# NOTA: in v2.7.x POST /api/v1/auth/login returneaza 501. SSO/IdP cutover
# ramane PR-10; tokenurile trebuie obtinute extern si pasate prin cookie sau
# Authorization: Bearer.
# /api/v1/auth/refresh cere token inca valid; dupa expirare userul face re-login
# in providerul din PR-10. Esec-ul este auditat ca auth.denied.
# Values: desktop, web
# OPTIONAL - default desktop
LEGAL_DASHBOARD_AUTH_MODE=desktop

# Backward-compatible alias accepted by the backend when
# LEGAL_DASHBOARD_AUTH_MODE is not set. Prefer LEGAL_DASHBOARD_AUTH_MODE in new
# configs.
# OPTIONAL
APP_MODE=

# Required when LEGAL_DASHBOARD_AUTH_MODE=web. Must be at least 32 chars.
# This PR adds the pluggable JWT/session validation seam; real Workspace SSO
# issuance is still a separate deployment/provider step.
# REQUIRED in web mode
LEGAL_DASHBOARD_JWT_SECRET=
# Alias accepted by the backend:
# JWT_SECRET=

# --- Personal Access Tokens (API programatic + MCP, piesa A; web mode only) ---
# Operational kill switch. Set to "1" to disable ALL PAT (ld_pat_*) auth per-request:
# a PAT-shaped Bearer falls back to the JWT path and fails as a normal 401. Desktop is
# unaffected (PAT path is web-only).
# OPTIONAL — default off
LEGAL_DASHBOARD_PAT_DISABLED=
# Per-token request rate limit (requests / minute / token), stricter than the per-owner
# ceiling. Applies only on the PAT path.
# OPTIONAL — default 60
LEGAL_DASHBOARD_TOKEN_RATE_LIMIT=
# DEV-ONLY escape hatch. Set to "1" ONLY for local HTTP testing of the PAT surface.
# NEVER set this in production: it disables the plaintext-PAT rejection, so a token could
# be sent over unencrypted HTTP. In a real deploy leave it UNSET — PAT then requires
# x-forwarded-proto: https (set by the TLS-terminating reverse proxy), else the request is
# rejected with 426. (The real HTTPS guarantee is the proxy + HSTS, not this flag.)
# OPTIONAL — default off (leave unset in production)
LEGAL_DASHBOARD_PAT_ALLOW_HTTP=
# Upper bound for a per-token captcha daily cap accepted at token creation.
# OPTIONAL — default 100000
MAX_TOKEN_CAPTCHA_CAP=

# Required token claims enforced in web mode. These prevent cross-product token
# replay when the same secret family is used by another system.
# REQUIRED in web mode
LEGAL_DASHBOARD_JWT_ISSUER=
LEGAL_DASHBOARD_JWT_AUDIENCE=
# Aliases accepted by the backend:
# JWT_ISSUER=
# JWT_AUDIENCE=

# Session/access token TTL for `/api/v1/auth/refresh`, in seconds.
# OPTIONAL - default 3600, allowed range 60..86400
LEGAL_DASHBOARD_JWT_TTL_SECONDS=
# Legacy alias still accepted:
# LEGAL_DASHBOARD_AUTH_TOKEN_TTL_SECONDS=

# Web auth cookies default to Secure. Set to "0" only for local HTTP testing.
# In production web mode, AUTH_COOKIE_SECURE=0 / LEGAL_DASHBOARD_AUTH_COOKIE_SECURE=0
# is a hard boot error.
# OPTIONAL
LEGAL_DASHBOARD_AUTH_COOKIE_SECURE=
# Alias accepted by the backend:
# AUTH_COOKIE_SECURE=

# Required in LEGAL_DASHBOARD_AUTH_MODE=web for centralized tenant API keys.
# Must be base64 that decodes to exactly 32 bytes. Store separately from DB
# backups; if lost, tenant_api_keys ciphertext is unrecoverable and the admin
# must re-enter all keys from /admin/keys. Optional in desktop mode.
TENANT_KEY_ENCRYPTION_SECRET=

# Monitoring global kill switch. Set to "0" to disable monitoring routes and
# scheduler. Desktop defaults to enabled.
# OPTIONAL - default enabled
MONITORING_ENABLED=

# Monitoring kill switch by job kind. Comma-separated list; matching due jobs
# are skipped by the scheduler while the process env var is set.
# Values: dosar_soap, name_soap, iccj, aviz_rnpm
# OPTIONAL
MONITORING_DISABLED_KINDS=

# Alerte source_partial / multi-instanta (succes partial in fan-out-ul de
# monitorizare). Activ by default din v2.37.1; "0" = kill switch (revine la
# console.warn-only).
# OPTIONAL - default activ
MONITORING_PARTIAL_ALERTS_ENABLED=

# Kill switch interactiv pentru rutele ICCJ (/api/dosare-iccj + /api/termene-iccj).
# "1" = ambele rute raspund 503; scheduler-ul se opreste separat prin
# MONITORING_DISABLED_KINDS=iccj.
# OPTIONAL
ICCJ_ROUTES_DISABLED=

# Timeout per-fetch pentru scraping-ul scj.ro, in ms.
# OPTIONAL - default 30000
ICCJ_TIMEOUT_MS=

# Cap pe dimensiunea unui raspuns scj.ro, in bytes.
# OPTIONAL - default 20971520 (20 MB)
ICCJ_MAX_RESPONSE_BYTES=

# Buget total (wall-clock) pentru imbogatirea detaliilor ICCJ per cautare, in ms.
# La expirare randurile ramase se intorc ne-imbogatite, fara eroare.
# OPTIONAL - default 45000
ICCJ_ENRICH_BUDGET_MS=

# Timeout per-fetch pentru upstream-ul RNPM (mj.rnpm.ro), in ms (v2.37.1).
# OPTIONAL - default 60000
RNPM_TIMEOUT_MS=

# RNPM runtime validation is fail-closed by default. Set to "1" only as temporary rollback if upstream schema drifts.
RNPM_RUNTIME_VALIDATION_DISABLED=

# RNPM autocompact after committed deletes. Disable semantically with "1" or
# tune the absolute freelist threshold in MB (default 10; finite fractions >=0).
LEGAL_DASHBOARD_RNPM_AUTOCOMPACT_DISABLED=
LEGAL_DASHBOARD_RNPM_AUTOCOMPACT_MIN_FREE_MB=

# Limite RNPM per user. Baza vie are implicit 500 MB; jail-ul de backup are
# plafon best-effort implicit 500 MB. Pentru oricare, 0 sau negativ = nelimitat.
LEGAL_DASHBOARD_DEFAULT_RNPM_STORAGE_MB=
LEGAL_DASHBOARD_RNPM_BACKUP_CAP_MB=

# Email notifiers (PR-11). Optional and OFF when incomplete. Credentials stay
# server-side in env; never commit backend/.env.
# OPTIONAL - ex: smtp.gmail.com, smtp-relay.gmail.com, smtp.resend.com
SMTP_HOST=
# OPTIONAL - 465 (SSL) or 587 (STARTTLS)
SMTP_PORT=
# OPTIONAL - SMTP username / relay account
SMTP_USER=
# OPTIONAL - Gmail App Password / SMTP API key, not the real account password
SMTP_PASS=
# OPTIONAL - From address, ex: alerts@example.com
SMTP_FROM=
# OPTIONAL - "true" on 465, "false" on 587; autodetected from port when empty
SMTP_SECURE=

LEGAL_DASHBOARD_BACKUP_OFFSITE_CMD=  # OPTIONAL — shell command run after each daily backup; equivalent to eval at host privilege, operator-set only

# BCE EUR/USD plausibility band. Defaults: 0.5..2.0. Out-of-band rates fail closed and are not saved.
FX_PLAUSIBLE_EUR_USD_MIN=
FX_PLAUSIBLE_EUR_USD_MAX=

# NOTE: NODE_ENV is intentionally NOT in this template. The Electron wrapper sets
# it to "production" automatically, and the Docker image hard-codes
# `ENV NODE_ENV=production`. Shipping `NODE_ENV=development` here would let an
# operator copy this file to a server deploy and silently activate dev-only
# branches (CORS dev origins, etc.). For local dev runs, export `NODE_ENV=development`
# in the shell — do not add it to the .env file copied alongside production deploys.

# NOTE for desktop v2.4.0: the 2Captcha / CapSolver key for RNPM captcha
# solving is NOT read from env. It is entered in the app at "Setari AI" →
# "2Captcha (RNPM)" and persisted via Electron safeStorage (OS keystore).
#
# Web mode v2.30.0: captcha provider keys are configured by admins in
# /admin/keys and stored encrypted in tenant_api_keys, never browser-supplied
# by non-admin users. Desktop keeps the safeStorage/UI flow.
#
# Provider links:
#   - https://2captcha.com/
#   - https://www.capsolver.com/
