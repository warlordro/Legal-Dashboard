# Legal Dashboard — backend environment variables
# Copy to backend/.env and fill in only what you need. All fields are OPTIONAL
# (API keys are normally configured via the in-app "Setari AI" dialog, which
# persists them in the local SQLite DB. Setting them here is a fallback).

# Anthropic Claude API key — https://console.anthropic.com/
# OPTIONAL — fallback if no key is configured in Setari AI
ANTHROPIC_API_KEY=

# OpenAI API key — https://platform.openai.com/api-keys
# OPTIONAL — fallback if no key is configured in Setari AI
OPENAI_API_KEY=

# Google AI (Gemini) API key — https://aistudio.google.com/app/apikey
# OPTIONAL — fallback if no key is configured in Setari AI
GOOGLE_AI_KEY=

# HTTP bind address for the backend (default 127.0.0.1 — keep this in Electron mode)
# OPTIONAL
HOST=127.0.0.1

# SQLite DB path — Electron sets this to %APPDATA%/legal-dashboard/legal-dashboard.db
# OPTIONAL — leave empty for default in dev (./legal-dashboard-dev.db)
LEGAL_DASHBOARD_DB_PATH=

# NODE_ENV — set automatically by Electron wrapper, override only for local dev
# OPTIONAL
NODE_ENV=development

# NOTE: The 2Captcha / CapSolver key for RNPM captcha solving is NOT read from
# env. It is entered in the app at "Setari AI" → card "2Captcha (RNPM)" and
# stored obfuscated in localStorage. Get a key at:
#   - https://2captcha.com/
#   - https://www.capsolver.com/
