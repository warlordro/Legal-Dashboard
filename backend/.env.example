# Legal Dashboard — backend environment variables
# Copy to backend/.env and fill in only what you need. All fields are OPTIONAL.
#
# AI provider keys: if set here, env takes PRECEDENCE over keys saved in the
# in-app "Setari AI" dialog. Leave blank to let users configure their own
# keys through the UI (stored in Electron safeStorage on desktop, obfuscated
# localStorage on web).

# Anthropic Claude API key — https://console.anthropic.com/
# OPTIONAL
ANTHROPIC_API_KEY=

# OpenAI API key — https://platform.openai.com/api-keys
# OPTIONAL
OPENAI_API_KEY=

# Google AI (Gemini) API key — https://aistudio.google.com/app/apikey
# OPTIONAL
GOOGLE_AI_KEY=

# HTTP bind address. Loopback only (127.0.0.1 / localhost / ::1) is accepted
# by default. Any other value is refused unless LEGAL_DASHBOARD_ALLOW_REMOTE=1
# is set explicitly — prevents accidental LAN exposure via a stray HOST=0.0.0.0.
# OPTIONAL — default 127.0.0.1
HOST=127.0.0.1

# Opt-in switch for binding to non-loopback addresses. Set to "1" together
# with HOST=0.0.0.0 (or a specific interface) when hosting the backend for
# multiple clients. Keep unset for desktop Electron use.
# OPTIONAL
LEGAL_DASHBOARD_ALLOW_REMOTE=

# Backend port. Electron injects this automatically; override only for
# manual runs or alternative port assignments.
# OPTIONAL — default 3002
LEGAL_DASHBOARD_PORT=

# SQLite DB path. Electron sets this to %APPDATA%/legal-dashboard/legal-dashboard.db
# OPTIONAL — leave empty for default in dev (./legal-dashboard-dev.db)
LEGAL_DASHBOARD_DB_PATH=

# NODE_ENV — set automatically by the Electron wrapper (to "production").
# Overriding to "development" enables DevTools and the dev menu entry.
# OPTIONAL
NODE_ENV=development

# NOTE: The 2Captcha / CapSolver key for RNPM captcha solving is NOT read
# from env. It is entered in the app at "Setari AI" → "2Captcha (RNPM)" and
# persisted via Electron safeStorage (OS keystore) on desktop, or base64
# obfuscation in localStorage on web. Get a key at:
#   - https://2captcha.com/
#   - https://www.capsolver.com/
