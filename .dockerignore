# SECURITY: keep secrets and local-only state out of the build context. Without
# this file, `docker build .` ships the entire repo (including .env.local,
# release/, server-release/, .git, node_modules) into image layers — secrets
# leak even if removed in later layers, because every layer is independently
# fetchable from the registry.

# Secrets / local config
.env
.env.*
!.env.example
.npmrc
*.pem
*.key

# VCS + IDE
.git
.gitignore
.github
.vscode
.idea
.claude

# Node + workspace caches
node_modules
**/node_modules
.npm
.pnpm-store

# Output dirs / artifacts not needed in the image. NOTE: the `builder` stage
# compiles dist-frontend/ + dist-backend/ from source (scripts/build.js), so the
# app source (scripts/, frontend/, backend/src) MUST stay in the build context.
release
server-release
build
dist-frontend
dist-backend
electron
*.log
*.tsbuildinfo

# OS noise
.DS_Store
Thumbs.db
