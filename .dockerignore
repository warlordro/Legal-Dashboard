# SECURITY: keep secrets and local-only state out of the build context. Without
# this file, `docker build .` ships the entire repo (including .env.local,
# release/, server-release/, .git, node_modules) into image layers — secrets
# leak even if removed in later layers, because every layer is independently
# fetchable from the registry.

# Secrets / local config
.env
.env.*
!.env.example
.npmrc
*.pem
*.key

# VCS + IDE
.git
.gitignore
.github
.vscode
.idea
.claude

# Node + workspace caches
node_modules
**/node_modules
.npm
.pnpm-store

# Local build artifacts. The image compiles its own dist-backend/dist-frontend
# in the `build` stage (see Dockerfile), so stale host builds must NOT leak in.
dist-backend
dist-frontend
frontend/dist
release
server-release
build
*.log
*.tsbuildinfo

# Not needed inside the image
electron
deploy
docs
audit
*.md
*.pdf
*.html

# OS noise
.DS_Store
Thumbs.db
