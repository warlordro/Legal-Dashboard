# Legal Dashboard — production deploy template.
# Copy to deploy/.env.prod and fill in real values. NEVER commit deploy/.env.prod.
# (deploy/.env.prod is gitignored.)
#
# Generators (run on the host, NOT inside the container):
#   JWT_SECRET             : openssl rand -base64 48
#   PROXY_BRIDGE_SECRET    : openssl rand -base64 48
#   TENANT_KEY_SECRET      : openssl rand -base64 32      (exactly 32 bytes raw)
#   OAUTH2_PROXY_COOKIE_SECRET : python3 -c 'import os,base64;print(base64.urlsafe_b64encode(os.urandom(32)).decode())'
#
# All secret values above are NEW per environment. Treat the .env.prod file
# itself as a critical credential: store a copy in a password manager / vault.

# ---- Domain & TLS -----------------------------------------------------------
# Public DNS name of the deployment, e.g. dashboard.firma.ro. Must already
# resolve to this host BEFORE first `docker compose up` (Let's Encrypt
# HTTP-01 challenge needs it).
DOMAIN=

# Contact email for Let's Encrypt (expiry warnings).
ACME_EMAIL=

# ---- Google OAuth (oauth2-proxy provider) ----------------------------------
# Create at https://console.cloud.google.com/apis/credentials
#   - Application type: Web application
#   - Authorized redirect URI: https://${DOMAIN}/oauth2/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Comma-separated list of email domains allowed to sign in. Use "*" for any.
# Recommended: restrict to your workspace domain(s).
OAUTH2_PROXY_EMAIL_DOMAINS=example.com

# 32-byte URL-safe base64. Rotating this invalidates ALL oauth2-proxy sessions.
OAUTH2_PROXY_COOKIE_SECRET=

# ---- Backend JWT auth -------------------------------------------------------
# Min 32 chars. Rotating this invalidates ALL backend JWT sessions (users will
# go through Google OAuth + bridge sync again on next request — UX impact small).
JWT_SECRET=
JWT_ISSUER=legal-dashboard-prod
JWT_AUDIENCE=legal-dashboard-prod
# Backend JWT lifetime in seconds (60..86400). Default 3600 (1h). Combined with
# oauth2-proxy cookie expiry of 7d, the user goes through the bridge endpoint
# silently every JWT_TTL_SECONDS as long as the proxy session is still valid.
JWT_TTL_SECONDS=3600

# ---- oauth2-proxy → backend bridge -----------------------------------------
# Shared secret sent upstream by oauth2-proxy as the Basic Auth password
# (`basic-auth-password` + `pass-basic-auth`) and validated by the backend on
# POST /api/v1/auth/oauth2/sync. Min 32 chars. Rotating it requires bouncing
# both services in lockstep (compose `up -d` rolling update does that
# automatically).
PROXY_BRIDGE_SECRET=

# ---- Tenant API key encryption ---------------------------------------------
# 32-byte master secret used by AES-256-GCM to encrypt tenant API keys stored
# in tenant_keys table. v2.30.0 boot probe rejects boot if missing or invalid.
# LOSING THIS KEY MAKES ALL STORED TENANT KEYS UNREADABLE — back it up.
TENANT_KEY_SECRET=

# ---- Optional: operational kill switches -----------------------------------
# Disable specific monitoring kinds without code changes: MONITORING_DISABLED_KINDS=dosar_soap,name_soap
LEGAL_DASHBOARD_TRUSTED_PROXY_CIDR=172.16.0.0/12
RNPM_RUNTIME_VALIDATION_DISABLED=
FX_PLAUSIBLE_EUR_USD_MIN=
FX_PLAUSIBLE_EUR_USD_MAX=
MONITORING_DISABLED_KINDS=

# ---- Optional: SMTP alerts (PR-11) -----------------------------------------
# Set ALL five (HOST/PORT/USER/PASS/FROM) to enable email alerts. Partial config
# logs a warning at boot and disables the mailer.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_SECURE=0

# ---- Optional: seed first admin --------------------------------------------
# Consumed only by scripts/seed-admin.mjs at first boot. Idempotent; safe to
# leave set across redeploys. After the first run you can rotate or unset.
SEED_ADMIN_EMAIL=
SEED_ADMIN_DISPLAY_NAME=

# ---- Optional: app version override ----------------------------------------
# Default matches release tag. Override only for rolling-deploy testing.
APP_VERSION=2.40.1
